# 单机 1× H100 微调实验平台 —— lab submit 配置模板。
# 复制为 cluster/submit.env，改两处即可用：RAY_DASHBOARD_ADDRESS 的 IP、RUN_USER。
#   cp cluster/submit.env.h100.example cluster/submit.env
#
# 用法（全程在自己机器上、经 VPN 连到 H100 机器，无需 SSH 进容器）：
#   1) 连上 VPN
#   2) uv run lab submit <实验名>          # 提交微调作业（本仓库代码随作业自动上传）
#   3) uv run lab job logs <job_id> -f     # 实时日志
#      uv run lab web                      # 本地面板看 reward 曲线 + 验证对话
# 详见 docs/remote-submit.md。完整可选字段见 cluster/submit.env.example。

# ---------- 连哪台机 ----------
# H100 机器上 Ray head 的 dashboard 地址（VPN 内可达；端口默认 8265）。
# 多台机器时改成你被分配的那台的 VPN IP。
RAY_DASHBOARD_ADDRESS=http://10.0.0.10:8265
# 容器内 NeMo-RL 0.6.0 的路径（容器内路径，不是你本机路径）。
NEMO_RL_DIR=/opt/NeMo-RL
# 单机单卡 profile（cluster/h100/）。
DEFAULT_CLUSTER_PROFILE=h100

# ---------- 你是谁（多人共用必填，做产物隔离）----------
# 产物（checkpoint + 样本 jsonl + 日志）落到 OUTPUT_ROOT/<RUN_USER>/<实验名>，各人互不覆盖。
RUN_USER=yourname
# 集群上的持久目录 / 共享盘（不要落在 Ray 临时目录，否则训练结束被清理）。
OUTPUT_ROOT=/data/nemo-rl-runs

# ---------- venv 复用（平台建议开）----------
# 容器里 NeMo-RL 的 venv 已装好时设 1：让 run.sh 的 uv run 跳过 sync，直接用现成环境，
# 提交更快，也避开 GitHub 直链依赖（flash-attn 等）偶发拉取失败拖垮作业。
UV_NO_SYNC=1

# ---------- 密钥 / 下载（按需）----------
# SwanLab：填了训练曲线才上云（也可不填，用 lab web 本地看）。
SWANLAB_API_KEY=
# 下载 gated 模型/数据集要 HF token；HF_HOME 是容器内模型缓存（须先 prefetch 或集群能直连 huggingface.co）。
# HF_TOKEN=
# HF_HOME=/data/hf_cache
HF_HUB_ENABLE_HF_TRANSFER=0

# ---------- 内部数据集（留在集群、不上传）----------
# 被 .gitignore 命中的内部数据（如题库 datasets/qa_rl/）不会随作业上传，须先放到集群，
# 再在这里指向【容器内绝对路径】，submit 会转发并覆盖自动推导。
# QA_RL_DATA_DIR=/data/datasets/qa_rl

# ---------- 简答题裁判 LLM / RAGFlow 检索（仅 qa 系列实验用，按需开；完整说明见 submit.env.example）----------
# JUDGE_BASE_URL=http://127.0.0.1:8001/v1
# JUDGE_MODEL=Qwen/Qwen2.5-7B-Instruct
# KB_BASE_URL=http://10.0.0.x:9380
# KB_API_KEY=ragflow-xxxxx
# KB_DATASET_IDS=id1,id2
