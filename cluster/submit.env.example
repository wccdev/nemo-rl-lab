# 提交配置·通用层（密钥 / 身份 / 默认 profile）—— 填一次，换集群不动这个文件。
#   cp cluster/submit.env.example cluster/submit.env
#
# 配置分两层（lab submit / submit_job.sh 先读通用层、再读集群专属层，后者覆盖前者）：
#   · 通用层 = 本文件 cluster/submit.env          —— 跨集群通用：密钥、RUN_USER、默认 profile
#   · 集群层 = cluster/<profile>/submit.env        —— 随集群走：地址、容器内路径（见 cluster/<profile>/submit.env.example）
# 换集群只需切 profile（实验自带 cluster 文件 / DEFAULT_CLUSTER_PROFILE / lab submit --profile），
# 地址/路径自动从对应集群层读，不必回头改同一个文件、也不会互相覆盖。
#
# 在集群容器内直接 `lab run` 时，把同样的密钥放到 cluster/secrets.env（也已 .gitignore），各实验 run.sh 会自动 source。

# ---------- 默认集群 profile（兜底）----------
# 每个实验自带 cluster 文件指定目标集群，一般无需这里。
# 本项用于：① 没自带 cluster 的实验兜底；② lab job / lab web 默认连哪个集群的 dashboard（可用 --profile 临时切）。
DEFAULT_CLUSTER_PROFILE=h100

# ---------- 你是谁（多人共用必填，做产物隔离）----------
# 产物隔离到 OUTPUT_ROOT/<RUN_USER>/<实验名>，各人互不覆盖；单人可留空。OUTPUT_ROOT 在集群层设。
# RUN_USER=yourname

# ---------- 密钥（submit 与 run 都会用到）----------
# SwanLab API Key（填了才上传云端日志；也可不填，用 lab web 本地看）
SWANLAB_API_KEY=
# HuggingFace token（下载 gated 模型/数据集需要，如 Llama、部分 Qwen）
HF_TOKEN=

# ---------- 下载 / 环境行为开关 ----------
# 启用 hf_transfer 高速下载（需容器内已装 hf_transfer 包）。集群首次拉模型建议 0。
HF_HUB_ENABLE_HF_TRANSFER=0
# UV_NO_SYNC=1：让集群 run.sh 的 `uv run` 跳过 sync、直接用已装好的 venv，提交更快，
# 也避开 GitHub 直链依赖(flash-attn 等)偶发拉取失败拖垮作业（venv 已建好时强烈建议设 1）。
UV_NO_SYNC=1
