# ============ 训练产物 / 大文件（绝不入库）============
# checkpoint / 权重
outputs/
output/
results/
checkpoints/
ckpt/
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
*.nemo
*.gguf
hf_export/
exported_model/

# 数据（只入库元数据与处理脚本，原始/大数据本地或对象存储）
datasets/**/raw/
datasets/**/data/
data/raw/
*.arrow
*.parquet
*.jsonl.gz
# 若数据集较小需入库，删除对应忽略行或用 git-lfs

# 题库为公司内部专有数据，整目录不入库（含原始 raw 与处理后的 jsonl）
datasets/qa_rl/

# 日志（SwanLab 本地缓存 / 其他 tracker）
swanlog/
swanlab/
wandb/
mlruns/
logs/
*.log
tensorboard/
events.out.tfevents.*

# Ray / 分布式临时文件
ray_results/
/tmp/ray/
*.pid

# 本地 run 台账（lab submit 追加；含 IP/用户，仅本地追溯用）
.lab/

# Web console frontend
web/node_modules/
web/dist/

# ============ Python ============
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/
.venv/
venv/
env/.venv/
.python-version

# ============ 密钥 / 本地配置 ============
.env
.env.*
*.key
secrets.*
*.local.yaml
*.local.yml
# 本地集群提交配置（含 IP / 密钥）
# submit.env：通用层（密钥 / RUN_USER / 默认 profile）；各 profile 子目录的 submit.env：集群专属（地址 / 容器路径）
cluster/submit.env
cluster/*/submit.env
cluster/**/hosts

# ============ 系统 / 编辑器 ============
.DS_Store
.idea/
.vscode/
*.swp
